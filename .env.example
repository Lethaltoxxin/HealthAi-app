# HealthAI App Environment Variables

# Groq API Key (FREE — get yours at https://console.groq.com)
VITE_GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (FREE — get yours at https://aistudio.google.com/apikey)
# Used for prescription/report scanning with Gemini Vision
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Firebase (optional)
# VITE_FIREBASE_API_KEY=your_firebase_key
# VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your_project_id
